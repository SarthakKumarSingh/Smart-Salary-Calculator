---
import { stateOptions } from '../data/states.js';

const { defaultState = 'TX' } = Astro.props;
const optionsJson = JSON.stringify(stateOptions);
---

<section class="tool-shell" id="calculator" aria-label="Salary Calculator">
  <div class="calculator-heading" style="text-align: center; margin-bottom: 32px;">
    <h2 style="font-size: 2rem; font-weight: 700; letter-spacing: -0.02em;">Calculate your take home salary</h2>
  </div>
  <div class="calculator-grid">
    <form class="panel calculator-form" id="paycheck-form" autocomplete="off">
      <!-- Row 1: Pay -->
      <fieldset>
        <legend>Income</legend>
        <div class="field-row">
          <label>
            Gross pay
            <input id="gross-pay" name="grossPay" type="number" min="0" step="100" value="85000" inputmode="decimal" />
          </label>
          <label>
            Pay type
            <select id="pay-type" name="payType">
              <option value="salary">Annual salary</option>
              <option value="hourly">Hourly wage</option>
            </select>
          </label>
        </div>

        <div class="field-row hourly-fields" id="hourly-fields" hidden>
          <label>
            Hours per week
            <input id="hours" name="hours" type="number" min="1" max="100" step="0.5" value="40" inputmode="decimal" />
          </label>
          <label>
            Weeks per year
            <input id="weeks" name="weeks" type="number" min="1" max="52" step="1" value="52" inputmode="numeric" />
          </label>
        </div>

        <div class="field-row">
          <label>
            Pay frequency
            <select id="frequency" name="frequency">
              <option value="26">Biweekly (26 paychecks)</option>
              <option value="24">Semi-monthly (24)</option>
              <option value="12">Monthly (12)</option>
              <option value="52">Weekly (52)</option>
            </select>
          </label>
          <label>
            Filing status
            <select id="filing-status" name="filingStatus">
              <option value="single">Single</option>
              <option value="married">Married filing jointly</option>
              <option value="head">Head of household</option>
            </select>
          </label>
        </div>

        <div class="field-row">
          <label>
            State
            <select id="state" name="state">
              {stateOptions.map((state) => (
                <option value={state.abbr} selected={state.abbr === defaultState}>{state.name}</option>
              ))}
            </select>
          </label>
          <label>
            Number of allowances / dependents
            <input id="allowances" name="allowances" type="number" min="0" max="20" step="1" value="0" inputmode="numeric" />
          </label>
        </div>
      </fieldset>

      <!-- Row 2: Pre-tax deductions -->
      <fieldset>
        <legend>Pre-tax deductions <small>(per paycheck)</small></legend>
        <div class="field-row">
          <label>
            401(k) / 403(b)
            <input id="pretax-401k" name="pretax401k" type="number" min="0" step="10" value="150" inputmode="decimal" />
          </label>
          <label>
            Health insurance premium
            <input id="pretax-health" name="pretaxHealth" type="number" min="0" step="10" value="0" inputmode="decimal" />
          </label>
        </div>
        <div class="field-row">
          <label>
            HSA contribution
            <input id="pretax-hsa" name="pretaxHSA" type="number" min="0" step="10" value="0" inputmode="decimal" />
          </label>
          <label>
            FSA contribution
            <input id="pretax-fsa" name="pretaxFSA" type="number" min="0" step="10" value="0" inputmode="decimal" />
          </label>
        </div>
      </fieldset>

      <!-- 2026 Provisions -->
      <fieldset>
        <legend>2026 Tax Provisions</legend>
        <div class="field-row">
          <label>
            Qualified Overtime/Tips (Annual)
            <input id="qualified-tips" name="qualifiedTips" type="number" min="0" step="100" value="0" inputmode="decimal" />
          </label>
          <label style="display:flex; flex-direction:row; align-items:center; gap:8px; cursor:pointer;">
            <input id="senior-deduction" type="checkbox" style="width:auto; min-height:auto; transform:scale(1.2);" />
            Age 65 or older
          </label>
        </div>
      </fieldset>

      <!-- Row 3: Other -->
      <fieldset>
        <legend>Additional withholding <small>(per paycheck)</small></legend>
        <div class="field-row">
          <label>
            Extra federal withholding
            <input id="extra-federal" name="extraFederal" type="number" min="0" step="10" value="0" inputmode="decimal" />
          </label>
          <label>
            Other post-tax deductions
            <input id="posttax" name="posttax" type="number" min="0" step="10" value="0" inputmode="decimal" />
          </label>
        </div>
      </fieldset>

      <div class="form-actions">
        <button type="submit" id="calc-submit-btn" class="btn-primary">Calculate</button>
        <button type="reset" class="btn-ghost">Reset all</button>
      </div>

      <!-- Reverse calculation toggle -->
      <div class="reverse-toggle">
        <label class="toggle-label">
          <input id="reverse-mode" type="checkbox" />
          <span class="toggle-track"><span class="toggle-knob"></span></span>
          Reverse calculation (net → gross)
        </label>
        <span class="toggle-hint">Enter your desired take-home pay and we'll calculate the gross salary needed.</span>
      </div>
    </form>

    <dialog id="results-modal" class="panel results-card modal" aria-labelledby="modal-title">
      <div class="modal-header">
        <h3 id="modal-title" style="margin: 0; font-size: 1.25rem;">Estimated Net Pay</h3>
        <button class="modal-close" id="close-modal" aria-label="Close modal">&times;</button>
      </div>
      <div class="modal-content">
      <!-- Ad Placeholder (Appears on Calculate) -->
      <div id="ad-container" class="panel" style="display: none; text-align: center; padding: 40px 20px; background: var(--soft); margin-bottom: 24px; border: 1px dashed var(--line);">
        <p style="color: var(--muted); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; font-weight: bold;">Advertisement</p>
        <div style="background: var(--line); height: 90px; max-width: 728px; margin: 0 auto; display: flex; align-items: center; justify-content: center; border-radius: 4px;">
          <span style="color: var(--ink); opacity: 0.5;">[ Google AdSense / Network Ad Placeholder ]</span>
        </div>
      </div>

      <div class="results-hero" style="border-top: none;">
        <output id="net-pay" class="net-pay">$0</output>
        <p id="pay-period-label" class="muted">per paycheck</p>
      </div>

      <!-- SVG Donut Chart -->
      <div class="chart-container" id="chart-container">
        <svg id="donut-chart" viewBox="0 0 200 200" class="donut-svg">
          <circle cx="100" cy="100" r="80" fill="none" stroke="var(--line)" stroke-width="28"/>
          <circle id="donut-federal" cx="100" cy="100" r="80" fill="none" stroke="#1C1B1A" stroke-width="28" stroke-dasharray="0 503" stroke-dashoffset="0" transform="rotate(-90 100 100)"/>
          <circle id="donut-social" cx="100" cy="100" r="80" fill="none" stroke="#4A4742" stroke-width="28" stroke-dasharray="0 503" stroke-dashoffset="0" transform="rotate(-90 100 100)"/>
          <circle id="donut-medicare" cx="100" cy="100" r="80" fill="none" stroke="#827C75" stroke-width="28" stroke-dasharray="0 503" stroke-dashoffset="0" transform="rotate(-90 100 100)"/>
          <circle id="donut-state" cx="100" cy="100" r="80" fill="none" stroke="#C8BFAF" stroke-width="28" stroke-dasharray="0 503" stroke-dashoffset="0" transform="rotate(-90 100 100)"/>
          <circle id="donut-net" cx="100" cy="100" r="80" fill="none" stroke="var(--accent)" stroke-width="28" stroke-dasharray="0 503" stroke-dashoffset="0" transform="rotate(-90 100 100)"/>
          <text x="100" y="95" text-anchor="middle" class="donut-center-label">Take Home</text>
          <text id="donut-percent" x="100" y="118" text-anchor="middle" class="donut-center-value">0%</text>
        </svg>
        <div class="chart-legend">
          <span class="legend-item"><i style="background:#1C1B1A"></i> Federal</span>
          <span class="legend-item"><i style="background:#4A4742"></i> SS</span>
          <span class="legend-item"><i style="background:#827C75"></i> Medicare</span>
          <span class="legend-item"><i style="background:#C8BFAF"></i> State</span>
          <span class="legend-item"><i style="background:var(--accent)"></i> Net</span>
        </div>
      </div>

      <!-- Summary breakdown -->
      <div class="summary-list">
        <div><span>Gross annual pay</span><strong id="annual-gross">$0</strong></div>
        <div><span>Pre-tax deductions</span><strong id="total-pretax">$0</strong></div>
        <div class="indent"><span>Federal income tax</span><strong id="federal-tax">$0</strong></div>
        <div class="indent"><span>Social Security (6.2%)</span><strong id="social-tax">$0</strong></div>
        <div class="indent"><span>Medicare (1.45%)</span><strong id="medicare-tax">$0</strong></div>
        <div class="indent"><span>State income tax</span><strong id="state-tax">$0</strong></div>
        <div class="highlight"><span>Total taxes withheld</span><strong id="total-tax">$0</strong></div>
        <div><span>Effective federal rate</span><strong id="eff-rate">0%</strong></div>
        <div><span>Effective total rate</span><strong id="eff-total-rate">0%</strong></div>
      </div>

      <!-- Multi-period table -->
      <details class="period-table-wrap">
        <summary>View all pay periods</summary>
        <table class="period-table" id="period-table">
          <thead>
            <tr><th>Period</th><th>Gross</th><th>Taxes</th><th>Net</th></tr>
          </thead>
          <tbody>
            <tr><td>Annual</td><td id="p-annual-g">–</td><td id="p-annual-t">–</td><td id="p-annual-n">–</td></tr>
            <tr><td>Monthly</td><td id="p-monthly-g">–</td><td id="p-monthly-t">–</td><td id="p-monthly-n">–</td></tr>
            <tr><td>Biweekly</td><td id="p-biweekly-g">–</td><td id="p-biweekly-t">–</td><td id="p-biweekly-n">–</td></tr>
            <tr><td>Weekly</td><td id="p-weekly-g">–</td><td id="p-weekly-t">–</td><td id="p-weekly-n">–</td></tr>
            <tr><td>Daily</td><td id="p-daily-g">–</td><td id="p-daily-t">–</td><td id="p-daily-n">–</td></tr>
          </tbody>
        </table>
      </details>

      <p id="state-note" class="note"></p>
      
      <div style="margin-top: 24px; display: flex; justify-content: center;">
        <button type="button" id="print-btn" class="btn-secondary modal-print-btn" aria-label="Print results">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V2h12v7"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          Print / Save Results
        </button>
      </div>
      
      </div> <!-- Closes modal-content -->
    </dialog>
  </div> <!-- Closes calculator-grid -->

  <!-- Calculation History -->
  <div class="history-section" id="history-section">
    <div class="history-header">
      <h3>Recent Calculations</h3>
      <button type="button" id="clear-history" class="btn-ghost" style="font-size:0.8rem; min-height:32px; padding:0 12px;">Clear all</button>
    </div>
    <div id="history-list" class="history-list">
      <p class="history-empty">No saved calculations yet. Your results will appear here automatically.</p>
    </div>
  </div>
</section>

<script define:vars={{ optionsJson }}>
  const states = JSON.parse(optionsJson);
  const byAbbr = Object.fromEntries(states.map((s) => [s.abbr, s]));

  const standardDeductions = { single: 16100, married: 32200, head: 24150 };

  const brackets = {
    single: [
      [12400, 0.10], [50400, 0.12], [105700, 0.22],
      [201775, 0.24], [256225, 0.32], [640600, 0.35], [Infinity, 0.37],
    ],
    married: [
      [24800, 0.10], [100800, 0.12], [211400, 0.22],
      [403550, 0.24], [512450, 0.32], [768700, 0.35], [Infinity, 0.37],
    ],
    head: [
      [17700, 0.10], [67450, 0.12], [105700, 0.22],
      [201750, 0.24], [256200, 0.32], [640600, 0.35], [Infinity, 0.37],
    ],
  };

  const form = document.getElementById('paycheck-form');
  const payType = document.getElementById('pay-type');
  const hourlyFields = document.getElementById('hourly-fields');
  const fmt = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
  const pct = (v) => (v * 100).toFixed(1) + '%';
  const money = (v) => fmt.format(Math.max(0, Number.isFinite(v) ? v : 0));
  const nv = (id) => Number(document.getElementById(id).value || 0);
  const CIRC = 2 * Math.PI * 80; // ~502.65

  function progressiveTax(income, brkts) {
    let tax = 0, last = 0;
    for (const [limit, rate] of brkts) {
      if (income <= last) break;
      tax += (Math.min(income, limit) - last) * rate;
      last = limit;
    }
    return tax;
  }

  function updateDonut(fedPct, ssPct, medPct, statePct, netPct) {
    let offset = 0;
    const segments = [
      ['donut-federal', fedPct],
      ['donut-social', ssPct],
      ['donut-medicare', medPct],
      ['donut-state', statePct],
      ['donut-net', netPct],
    ];
    for (const [id, p] of segments) {
      const len = p * CIRC;
      const el = document.getElementById(id);
      el.style.transition = 'stroke-dasharray 0.5s ease, stroke-dashoffset 0.5s ease';
      el.setAttribute('stroke-dasharray', `${len} ${CIRC - len}`);
      el.setAttribute('stroke-dashoffset', `${-offset}`);
      offset += len;
    }
    document.getElementById('donut-percent').textContent = (netPct * 100).toFixed(0) + '%';
  }

  function calculate() {
    const frequency = nv('frequency');
    const status = document.getElementById('filing-status').value;
    const sel = byAbbr[document.getElementById('state').value] || byAbbr.TX;

    // Pre-tax deductions (per paycheck → annual)
    const pretax401k = nv('pretax-401k') * frequency;
    const pretaxHealth = nv('pretax-health') * frequency;
    const pretaxHSA = nv('pretax-hsa') * frequency;
    const pretaxFSA = nv('pretax-fsa') * frequency;
    const pretaxTotal = pretax401k + pretaxHealth + pretaxHSA + pretaxFSA;

    const posttaxAnnual = nv('posttax') * frequency;
    const extraFederalAnnual = nv('extra-federal') * frequency;

    const grossAnnual = payType.value === 'hourly'
      ? nv('gross-pay') * nv('hours') * nv('weeks')
      : nv('gross-pay');

    const wageAfterPretax = Math.max(0, grossAnnual - pretaxTotal);

    // 2026 Overhaul Deductions
    let seniorDed = 0;
    if (document.getElementById('senior-deduction').checked) {
      if (status === 'single' || status === 'head') {
        seniorDed = wageAfterPretax <= 75000 ? 6000 : 0;
      } else if (status === 'married') {
        seniorDed = wageAfterPretax <= 150000 ? 12000 : 0;
      }
    }

    let tipsInput = nv('qualified-tips');
    let tipsDed = 0;
    if (status === 'single' || status === 'head') {
      if (wageAfterPretax <= 150000) {
        tipsDed = Math.min(tipsInput, 12500);
      }
    } else if (status === 'married') {
      if (wageAfterPretax <= 300000) {
        tipsDed = Math.min(tipsInput, 25000);
      }
    }
    const totalNewDeductions = seniorDed + tipsDed;

    // Federal
    const taxableFederal = Math.max(0, wageAfterPretax - standardDeductions[status] - totalNewDeductions);
    const federal = progressiveTax(taxableFederal, brackets[status]) + extraFederalAnnual;

    // FICA
    const social = Math.min(wageAfterPretax, 184500) * 0.062;
    const medicareLimit = status === 'married' ? 250000 : 200000;
    const medicare = wageAfterPretax * 0.0145 + Math.max(0, wageAfterPretax - medicareLimit) * 0.009;

    // State — use progressive brackets if available
    let stateTax = 0;
    if (sel.brackets && sel.brackets.length > 0) {
      const stateDeduction = sel.stdDeduction || 0;
      const taxableState = Math.max(0, wageAfterPretax - stateDeduction);
      stateTax = progressiveTax(taxableState, sel.brackets);
    }

    const totalTax = federal + social + medicare + stateTax;
    const netAnnual = Math.max(0, grossAnnual - pretaxTotal - posttaxAnnual - totalTax);

    // Update displays
    document.getElementById('net-pay').textContent = money(netAnnual / frequency);
    document.getElementById('annual-gross').textContent = money(grossAnnual);
    document.getElementById('total-pretax').textContent = money(pretaxTotal);
    document.getElementById('federal-tax').textContent = money(federal);
    document.getElementById('social-tax').textContent = money(social);
    document.getElementById('medicare-tax').textContent = money(medicare);
    document.getElementById('state-tax').textContent = money(stateTax);
    document.getElementById('total-tax').textContent = money(totalTax);

    // Effective rates
    const effFed = grossAnnual > 0 ? federal / grossAnnual : 0;
    const effTotal = grossAnnual > 0 ? totalTax / grossAnnual : 0;
    document.getElementById('eff-rate').textContent = pct(effFed);
    document.getElementById('eff-total-rate').textContent = pct(effTotal);

    // Donut chart
    if (grossAnnual > 0) {
      updateDonut(
        federal / grossAnnual,
        social / grossAnnual,
        medicare / grossAnnual,
        stateTax / grossAnnual,
        netAnnual / grossAnnual
      );
    }

    // Multi-period table
    const periods = { annual: 1, monthly: 12, biweekly: 26, weekly: 52, daily: 260 };
    for (const [period, divisor] of Object.entries(periods)) {
      document.getElementById(`p-${period}-g`).textContent = money(grossAnnual / divisor);
      document.getElementById(`p-${period}-t`).textContent = money(totalTax / divisor);
      document.getElementById(`p-${period}-n`).textContent = money(netAnnual / divisor);
    }

    // State note
    const localNote = sel.hasLocalTax ? ' Additional local/city taxes may apply.' : '';
    document.getElementById('state-note').textContent =
      `${sel.name} ${sel.note}.${localNote} W-4 elections, bonuses, and benefit rules can change your real paycheck.`;
  }

  // Event listeners
  payType.addEventListener('change', () => {
    hourlyFields.hidden = payType.value !== 'hourly';
    calculate();
  });

  // Show modal on submit
  const resultsModal = document.getElementById('results-modal');
  const adContainer = document.getElementById('ad-container');
  
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    if (adContainer) adContainer.style.display = 'block';
    calculate();
    resultsModal.showModal();
  });

  document.getElementById('close-modal').addEventListener('click', () => {
    resultsModal.close();
  });

  resultsModal.addEventListener('click', (e) => {
    const rect = resultsModal.getBoundingClientRect();
    const isInDialog = (rect.top <= e.clientY && e.clientY <= rect.top + rect.height &&
      rect.left <= e.clientX && e.clientX <= rect.left + rect.width);
    if (!isInDialog) {
      resultsModal.close();
    }
  });

  document.getElementById('print-btn')?.addEventListener('click', () => window.print());

  // ─── Reverse Calculation (net → gross) ───
  const reverseToggle = document.getElementById('reverse-mode');
  const grossInput = document.getElementById('gross-pay');
  const grossLabel = grossInput.closest('label');

  reverseToggle.addEventListener('change', () => {
    const isReverse = reverseToggle.checked;
    grossLabel.childNodes[0].textContent = isReverse ? 'Desired net pay' : 'Gross pay';
    document.querySelector('.results-hero .eyebrow').textContent = isReverse ? 'Required gross salary' : 'Estimated net pay';
    if (isReverse) {
      reverseCalculate();
    } else {
      calculate();
    }
  });

  function reverseCalculate() {
    const desiredNet = nv('gross-pay');
    if (desiredNet <= 0) return;
    // Binary search for the gross that produces the desired net
    let lo = desiredNet, hi = desiredNet * 3, mid, netResult;
    for (let i = 0; i < 50; i++) {
      mid = (lo + hi) / 2;
      netResult = computeNetFromGross(mid);
      if (Math.abs(netResult - desiredNet) < 1) break;
      if (netResult < desiredNet) lo = mid;
      else hi = mid;
    }
    // Display the required gross
    document.getElementById('net-pay').textContent = money(mid / nv('frequency'));
    document.getElementById('annual-gross').textContent = money(mid);
  }

  function computeNetFromGross(grossAnnual) {
    const frequency = nv('frequency');
    const status = document.getElementById('filing-status').value;
    const sel = byAbbr[document.getElementById('state').value] || byAbbr.TX;
    const pretax401k = nv('pretax-401k') * frequency;
    const pretaxHealth = nv('pretax-health') * frequency;
    const pretaxHSA = nv('pretax-hsa') * frequency;
    const pretaxFSA = nv('pretax-fsa') * frequency;
    const pretaxTotal = pretax401k + pretaxHealth + pretaxHSA + pretaxFSA;
    const posttaxAnnual = nv('posttax') * frequency;
    const extraFederalAnnual = nv('extra-federal') * frequency;
    const wageAfterPretax = Math.max(0, grossAnnual - pretaxTotal);
    const taxableFederal = Math.max(0, wageAfterPretax - standardDeductions[status]);
    const federal = progressiveTax(taxableFederal, brackets[status]) + extraFederalAnnual;
    const social = Math.min(wageAfterPretax, 184500) * 0.062;
    const medicareLimit = status === 'married' ? 250000 : 200000;
    const medicare = wageAfterPretax * 0.0145 + Math.max(0, wageAfterPretax - medicareLimit) * 0.009;
    let stateTax = 0;
    if (sel.brackets && sel.brackets.length > 0) {
      const stateDeduction = sel.stdDeduction || 0;
      const taxableState = Math.max(0, wageAfterPretax - stateDeduction);
      stateTax = progressiveTax(taxableState, sel.brackets);
    }
    const totalTax = federal + social + medicare + stateTax;
    return Math.max(0, grossAnnual - pretaxTotal - posttaxAnnual - totalTax);
  }

  // Override calculate to also handle reverse mode
  const origCalc = calculate;
  form.removeEventListener('input', calculate);
  form.removeEventListener('change', calculate);
  form.addEventListener('input', () => reverseToggle.checked ? reverseCalculate() : origCalc());
  form.addEventListener('change', () => reverseToggle.checked ? reverseCalculate() : origCalc());

  // ─── Calculation History (localStorage) ───
  const HISTORY_KEY = 'smart_salary_calculator_history';
  const MAX_HISTORY = 5;

  function getHistory() {
    try { return JSON.parse(localStorage.getItem(HISTORY_KEY)) || []; }
    catch { return []; }
  }

  function saveToHistory() {
    if (reverseToggle.checked) return; // Don't save reverse calcs
    const gross = nv('gross-pay');
    if (gross <= 0) return;
    const state = document.getElementById('state').value;
    const status = document.getElementById('filing-status').value;
    const net = document.getElementById('net-pay').textContent;
    const totalTax = document.getElementById('total-tax').textContent;
    const entry = {
      id: Date.now(),
      date: new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
      gross: money(gross),
      state,
      status,
      net,
      tax: totalTax,
    };
    const history = getHistory();
    // Don't save duplicate of last entry
    if (history.length > 0 && history[0].gross === entry.gross && history[0].state === entry.state) return;
    history.unshift(entry);
    if (history.length > MAX_HISTORY) history.pop();
    localStorage.setItem(HISTORY_KEY, JSON.stringify(history));
    renderHistory();
  }

  function renderHistory() {
    const list = document.getElementById('history-list');
    const history = getHistory();
    if (history.length === 0) {
      list.innerHTML = '<p class="history-empty">No saved calculations yet. Your results will appear here automatically.</p>';
      return;
    }
    list.innerHTML = `<table class="history-table">
      <thead><tr><th>Date</th><th>Gross</th><th>State</th><th>Filing</th><th>Taxes</th><th>Net/check</th><th></th></tr></thead>
      <tbody>${history.map(h => `<tr>
        <td>${h.date}</td><td>${h.gross}</td><td>${h.state}</td>
        <td style="text-transform:capitalize">${h.status}</td><td>${h.tax}</td><td><strong>${h.net}</strong></td>
        <td><button class="history-del" data-id="${h.id}" title="Remove">✕</button></td>
      </tr>`).join('')}</tbody>
    </table>`;
    list.querySelectorAll('.history-del').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = Number(btn.dataset.id);
        const filtered = getHistory().filter(h => h.id !== id);
        localStorage.setItem(HISTORY_KEY, JSON.stringify(filtered));
        renderHistory();
      });
    });
  }

  // Save after user stops interacting for 1.5s
  let saveTimer;
  form.addEventListener('input', () => {
    clearTimeout(saveTimer);
    saveTimer = setTimeout(saveToHistory, 1500);
  });

  document.getElementById('clear-history')?.addEventListener('click', () => {
    localStorage.removeItem(HISTORY_KEY);
    renderHistory();
  });

  // Initial render
  renderHistory();
  calculate();
</script>

